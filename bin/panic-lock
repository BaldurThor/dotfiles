#!/usr/bin/env zsh

# 1. Identify and vaporize all external windows
# We use standard 'awk' to parse the text output, completely bypassing the broken JSON!
addresses=$(hyprctl clients | awk '/^Window / { addr=$2 } /^[ \t]*title: / { title=$0; sub(/^[ \t]*title:[ \t]*/, "", title); if (title != "Secure Terminal Enclave") print addr }')

# 2. Iterate through extracted addresses and cleanly close them
for addr in ${(f)addresses}; do
    if [[ -n "$addr" ]]; then
        hyprctl dispatch closewindow address:$addr >/dev/null 2>&1
        # Tiny pause to let the Wayland surface drop cleanly
        sleep 0.05
    fi
done

# 3. Trigger the lock screen by dynamically dropping ALL interactive authenticated shells
# Using pkill with the -f flag targets the exact "zsh -i" command signature, no PID file required!
pkill -HUP -f "zsh -i"
