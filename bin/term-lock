#!/usr/bin/env zsh
# Ignore Ctrl+C so users cannot break out of the secure interface loop
trap '' SIGINT

while true; do
    clear
    
    # Print system aesthetics with Fastfetch
    fastfetch
    
    echo ""
    echo -e "\e[36mSecure Terminal Enclave. Awaiting Authentication...\e[0m"
    echo ""
    
    # Authenticate and securely carry the Wayland instance state into your active Zsh profile
    su Baldur
done
