#!/usr/bin/env zsh
trap '' SIGINT

while true; do
    clear
    fastfetch
    
    echo ""
    echo -e "\e[36mSecure Terminal Enclave. Awaiting Authentication...\e[0m"
    echo ""
    
    # Authenticate and drop straight into the interactive shell
    su Baldur -c "export WAYLAND_DISPLAY=$WAYLAND_DISPLAY XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR HYPRLAND_INSTANCE_SIGNATURE=$HYPRLAND_INSTANCE_SIGNATURE; exec zsh -i"
    
    # Tiny breather to prevent CPU spiking in case of shell crashes
    sleep 1
done
